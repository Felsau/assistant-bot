# Telegram — get the token from @BotFather
TELEGRAM_BOT_TOKEN=
# Any random string; passed to setWebhook and verified on each request
TELEGRAM_WEBHOOK_SECRET=

# Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase — Project Settings → API
SUPABASE_URL=
# Use the service_role key on the server (never expose it client-side)
SUPABASE_KEY=

# Public base URL of the deployed app, e.g. https://assistant-bot.onrender.com
# On Render/Railway this is auto-detected; only set it for local tunnels (ngrok).
# When set (or auto-detected), the webhook registers itself on startup.
WEBHOOK_URL=

# Private access: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow anyone (not recommended — it spends your Claude credit).
# Find your ID by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=

# Secret protecting the /cron/daily-digest endpoint (any random string).
# A scheduler must send it as ?secret=... or the X-Cron-Secret header.
CRON_SECRET=

# Optional: enable voice messages by transcribing them with Whisper.
# Leave blank to disable voice (the bot will ask the user to type).
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
